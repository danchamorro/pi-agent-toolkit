{
  "mcpServers": {
    "jcodemunch": {
      "command": "uvx",
      "args": ["jcodemunch-mcp@latest"]
    },
    "pg-example-prod": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "DATABASE_URI",
        "crystaldba/postgres-mcp",
        "--access-mode=restricted"
      ],
      "env": {
        "DATABASE_URI": "postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
      },
      "lifecycle": "lazy"
    },
    "mariadb-example-local": {
      "command": "uvx",
      "args": [
        "--from",
        "iflow-mcp_mariadb-mariadb-server",
        "mariadb-server"
      ],
      "env": {
        "DB_HOST": "127.0.0.1",
        "DB_PORT": "3306",
        "DB_USER": "readonly_user",
        "DB_PASSWORD": "your_password",
        "DB_NAME": "your_database",
        "MCP_READ_ONLY": "true",
        "MCP_MAX_POOL_SIZE": "5"
      },
      "lifecycle": "lazy"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ]
    }
  }
}
