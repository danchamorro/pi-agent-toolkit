{
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint packages/",
    "lint:fix": "eslint packages/ --fix",
    "format": "prettier --write packages/",
    "format:check": "prettier --check packages/",
    "typecheck": "npm run typecheck:packages && npm run typecheck --workspaces --if-present",
    "typecheck:packages": "tsc --noEmit --project tsconfig.packages.json",
    "typecheck:dotfiles": "tsc --noEmit --project dotfiles/tsconfig.json",
    "test": "npm run test --workspaces --if-present",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test",
    "check:docs": "node scripts/check-docs.mjs",
    "setup": "node setup.mjs",
    "link": "node setup.mjs --link",
    "dev:sync": "node setup.mjs --link --skip-external --skip-packages",
    "update:third-party": "node setup.mjs",
    "update:skills": "node setup.mjs --skip-packages",
    "update:packages": "node setup.mjs --skip-external",
    "prepare": "git config core.hooksPath .hooks"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typebox": "^1.1.24",
    "typescript-eslint": "^8.57.2"
  }
}
